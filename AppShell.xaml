<?xml version="1.0" encoding="utf-8" ?>
<Shell xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
       xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
       xmlns:local="clr-namespace:ODapp"
       x:Class="ODapp.AppShell">

    <ShellContent Title="Main Page"
                  ContentTemplate="{DataTemplate local:MainPage}"
                  Route="MainPage" />

    <ShellContent Title="Login Page"
                  ContentTemplate="{DataTemplate local:LoginPage}"
                  Route="LoginPage" />

    <ShellContent Title="Namelist Page"
                  ContentTemplate="{DataTemplate local:NamelistPage}"
                  Route="NamelistPage" />

    <ShellContent Title="ODDetails Page"
                  ContentTemplate="{DataTemplate local:ODDetailsPage}"
                  Route="ODDetailsPage" />

    <ShellContent Title="ODDetails Form Page"
                  ContentTemplate="{DataTemplate local:ODDetailsFormPage}"
                  Route="ODDetailsFormPage" />

</Shell>
